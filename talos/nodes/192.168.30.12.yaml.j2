---
machine:
  type: controlplane
  nodeLabels:
    topology.kubernetes.io/zone: dmf-u
  install:
    diskSelector:
      model: Samsung SSD 870
    image: factory.talos.dev/installer/ddf18f2131db9f44b9999130d14fc66cf6d32ecabfc0ec0f1b873ee8aea0a937:v1.13.6 # eGPU variant - see `just talos gen-schematic-id-egpu`
    wipe: false
  kernel:
    modules:
      - name: nvidia        # eGPU - RTX 3090
      - name: nvidia_uvm    # eGPU - CUDA unified virtual memory
      - name: nvidia_drm    # eGPU - DRM/KMS integration
      - name: nvidia_modeset # eGPU - required by the driver even headless
---
apiVersion: v1alpha1
kind: HostnameConfig
hostname: k8s-2
