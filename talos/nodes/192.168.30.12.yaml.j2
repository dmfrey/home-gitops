---
machine:
  type: controlplane
  nodeLabels:
    topology.kubernetes.io/zone: dmf-u
  install:
    diskSelector:
      model: Samsung SSD 870
    image: factory.talos.dev/installer/78af732d1ef375ae1585448c74c792270f471d91d49376ce9ecaaf56024709ba:v1.13.6 # eGPU variant - see `just talos gen-schematic-id-egpu`
    wipe: false
  kernel:
    modules:
      - name: nvidia        # eGPU - RTX 5070
      - name: nvidia_uvm    # eGPU - CUDA unified virtual memory
      - name: nvidia_drm    # eGPU - DRM/KMS integration
      - name: nvidia_modeset # eGPU - required by the driver even headless
---
apiVersion: v1alpha1
kind: HostnameConfig
hostname: k8s-2
