---
machine:
  type: controlplane
  nodeLabels:
    topology.kubernetes.io/zone: dmf-u
  install:
    diskSelector:
      model: Samsung SSD 870
    image: factory.talos.dev/installer/2e57cd43682fc75c87cb523beb388d46a42f43ae510bb31ab6ae53e15d8bcfd5:v1.13.6 # eGPU variant - see `just talos gen-schematic-id-egpu`
    wipe: false
  kernel:
    modules:
      - name: nvidia        # eGPU - RTX 5070
      - name: nvidia_uvm    # eGPU - CUDA unified virtual memory
      - name: nvidia_drm    # eGPU - DRM/KMS integration
      - name: nvidia_modeset # eGPU - required by the driver even headless
---
apiVersion: v1alpha1
kind: HostnameConfig
hostname: k8s-2
