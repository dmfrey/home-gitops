---
version: v1alpha1
machine:

  ca:
    crt: op://kubernetes/talos/MACHINE_CA_CRT
    {% if ENV.IS_CONTROLLER %}
    key: op://kubernetes/talos/MACHINE_CA_KEY
    {% endif %}

  features:
    apidCheckExtKeyUsage: true
    diskQuotaSupport: true
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: true # Requires Cilium socketLB features (confirmed active)
      resolveMemberNames: true
    kubePrism:
      enabled: true
      port: 7445
    {% if ENV.IS_CONTROLLER %}
    kubernetesTalosAPIAccess:
      allowedKubernetesNamespaces:
        - actions-runner-system
        - system-upgrade
      allowedRoles:
        - os:admin
      enabled: true
    {% endif %}
    rbac: true

  files:
    - op: create
      path: /etc/cri/conf.d/20-customization.part
      content: |
        [plugins."io.containerd.cri.v1.images"]
          discard_unpacked_layers = false
        [plugins."io.containerd.cri.v1.runtime"]
          cdi_spec_dirs = ["/var/cdi/static", "/var/cdi/dynamic"]
          device_ownership_from_security_context = true
    - op: overwrite
      path: /etc/nfsmount.conf
      permissions: 0o644
      content: |
        [ NFSMount_Global_Options ]
        nfsvers=4.1
        hard=True
        nconnect=16
        noatime=True

  install:
    diskSelector:
      model: Samsung SSD 870
    image: factory.talos.dev/installer/cfd2afa428fa5a48f71d9c0583c2fd870ce72d610861bc6f051bc55abf6c65b2:v1.12.7
    wipe: false

  time:
    servers:
      - 192.168.30.1      # UDM-SE gateway on homelab VLAN — prefer local over internet
      - time.cloudflare.com

  kubelet:
    defaultRuntimeSeccompProfileEnabled: true
    disableManifestsDirectory: true
    extraConfig:
      featureGates:
        ImageVolume: true
        # ResourceHealthStatus: true  # re-enable when intel-gpu-resource-driver implements v1alpha1.DRAResourceHealth (currently causes kubelet spam on k8s-2)
        UserNamespacesSupport: true
      imageMaximumGCAge: 24h
      imageGCHighThresholdPercent: 65
      imageGCLowThresholdPercent: 50
      serializeImagePulls: false
    image: ghcr.io/siderolabs/kubelet:v1.35.4
    nodeIP:
      validSubnets:
        - 192.168.30.0/24

  nodeLabels:
    node.kubernetes.io/gpu: "true"
    topology.kubernetes.io/region: dmf

  sysctls:
    # --- Filesystem Watchers ---
    fs.inotify.max_user_instances: "8192"
    fs.inotify.max_user_watches: "1048576"

    # --- Virtual Memory Tuning ---
    vm.dirty_background_ratio: "5"
    vm.dirty_ratio: "10"
    vm.swappiness: "0"                         # No swap on Talos; explicit for Kubernetes best practice
    vm.min_free_kbytes: "1048576"              # Reserve 1GB free — prevents OOM during Rook-Ceph I/O bursts on 64GB nodes

    # --- Network Performance Tuning (2.5GbE) ---
    net.core.default_qdisc: fq
    net.core.netdev_max_backlog: "5000"        # Default 1000 is tuned for 1GbE
    net.core.rmem_max: "16777216"              # 16MB — improves NFS throughput with nconnect=16
    net.core.somaxconn: "4096"
    net.core.wmem_max: "16777216"              # 16MB — improves NFS throughput with nconnect=16
    net.ipv4.tcp_congestion_control: bbr
    net.ipv4.tcp_mtu_probing: "1"             # Enable MTU probing for Cilium pod networking
    net.ipv4.tcp_rmem: 4096 87380 16777216
    net.ipv4.tcp_wmem: 4096 65536 16777216

    # --- NFS Client Tuning ---
    sunrpc.tcp_max_slot_table_entries: "128"

    # --- Process & Namespace Limits ---
    user.max_user_namespaces: "11255"
    kernel.pid_max: "1048576"              # Default 32768 is too low for large clusters; prevents PID exhaustion

  sysfs:
    devices.system.cpu.intel_pstate.hwp_dynamic_boost: "1"
    kernel.mm.transparent_hugepage.enabled: never    # Eliminate THP compaction latency spikes (etcd, PostgreSQL)
    kernel.mm.transparent_hugepage.defrag: never     # Stop background memory compaction entirely
    # energy_performance_preference is per-core on i7-13620H — not available at
    # intel_pstate level. Per-core path: /sys/devices/system/cpu/cpuX/cpufreq/energy_performance_preference
    # Current default is "balance_performance" which is appropriate for mini PC thermals.

  network:
    nameservers:
      - 192.168.30.1    # UDM-SE — primary, local/private DNS
      - 1.1.1.1         # Cloudflare — fallback for TCP reconnect windows and boot-time gaps

  token: op://kubernetes/talos/MACHINE_TOKEN

  udev:
    rules:
      - KERNEL=="ttyUSB[0-9]", GROUP="20", MODE="0660"
      - SUBSYSTEM=="drm", KERNEL=="renderD*", GROUP="44", MODE="0660"

cluster:
  ca:
    crt: op://kubernetes/talos/CLUSTER_CA_CRT
    {% if ENV.IS_CONTROLLER %}
    key: op://kubernetes/talos/CLUSTER_CA_KEY
    {% endif %}

  clusterName: k8s

  controlPlane:
    endpoint: https://k8s.internal:6443

  discovery:
    enabled: true
    registries:
      kubernetes:
        disabled: true
      service:
        disabled: false

  id: op://kubernetes/talos/CLUSTER_ID

  network:
    cni:
      name: none
    dnsDomain: cluster.local
    podSubnets:
      - 10.42.0.0/16
    serviceSubnets:
      - 10.43.0.0/16

  secret: op://kubernetes/talos/CLUSTER_SECRET

  token: op://kubernetes/talos/CLUSTER_TOKEN

  {% if ENV.IS_CONTROLLER %}
  aggregatorCA:
    crt: op://kubernetes/talos/CLUSTER_AGGREGATORCA_CRT
    key: op://kubernetes/talos/CLUSTER_AGGREGATORCA_KEY

  allowSchedulingOnControlPlanes: true

  apiServer:
    auditPolicy:
      apiVersion: audit.k8s.io/v1
      kind: Policy
      rules:
        - level: Metadata
    certSANs:
      - k8s.internal

    disablePodSecurityPolicy: true

    extraArgs:
      enable-aggregator-routing: "true"
      # ResourceHealthStatus removed until intel-gpu-resource-driver implements v1alpha1.DRAResourceHealth
      feature-gates: HPAScaleToZero=true,ImageVolume=true,MutatingAdmissionPolicy=true,UserNamespacesSupport=true
      runtime-config: admissionregistration.k8s.io/v1beta1=true

    image: registry.k8s.io/kube-apiserver:v1.35.4

  controllerManager:
    extraArgs:
      bind-address: 0.0.0.0
    image: registry.k8s.io/kube-controller-manager:v1.35.4

  coreDNS:
    disabled: true

  etcd:
    advertisedSubnets:
      - 192.168.30.0/24
    ca:
      crt: op://kubernetes/talos/CLUSTER_ETCD_CA_CRT
      key: op://kubernetes/talos/CLUSTER_ETCD_CA_KEY
    extraArgs:
      listen-metrics-urls: http://0.0.0.0:2381

  proxy:
    disabled: true
    image: registry.k8s.io/kube-proxy:v1.35.4

  scheduler:
    config:
      apiVersion: kubescheduler.config.k8s.io/v1
      kind: KubeSchedulerConfiguration
      profiles:
        - schedulerName: default-scheduler
          plugins:
            score:
              disabled:
                - name: ImageLocality
          pluginConfig:
            - name: PodTopologySpread
              args:
                defaultingType: List
                defaultConstraints:
                  - maxSkew: 1
                    topologyKey: kubernetes.io/hostname
                    whenUnsatisfiable: ScheduleAnyway
    extraArgs:
      bind-address: 0.0.0.0
    image: registry.k8s.io/kube-scheduler:v1.35.4

  secretboxEncryptionSecret: op://kubernetes/talos/CLUSTER_SECRETBOXENCRYPTIONSECRET

  serviceAccount:
    key: op://kubernetes/talos/CLUSTER_SERVICEACCOUNT_KEY
  {% endif %}

---
apiVersion: v1alpha1
kind: LinkConfig
name: eth0
mtu: 1500
up: true
addresses: []

---
apiVersion: v1alpha1
kind: DHCPv4Config
name: eth0
clientIdentifier: mac

---
apiVersion: v1alpha1
kind: VLANConfig
name: eth0.50
vlanID: 50
parent: eth0
mtu: 1500

---
apiVersion: v1alpha1
kind: VLANConfig
name: eth0.90
vlanID: 90
parent: eth0
mtu: 1500

---
apiVersion: v1alpha1
kind: UserVolumeConfig
name: local-hostpath
provisioning:
  diskSelector:
    match: disk.model == "NT-128 2242"  # && !system_disk
  minSize: 50GB

---
apiVersion: v1alpha1
kind: WatchdogTimerConfig
device: /dev/watchdog0
timeout: 5m

---
apiVersion: v1alpha1
kind: ExtensionServiceConfig
name: nut-client
configFiles:
  - content: |-
        op://kubernetes/unifi/NUT_MONITOR
        SHUTDOWNCMD "/sbin/poweroff"
    mountPath: /usr/local/etc/nut/upsmon.conf
