---
customization:
  extraKernelArgs:
    - -init_on_alloc                      # Less security, faster puter
    - -init_on_free                       # Less security, faster puter
    - -selinux                            # Less security, faster puter

    # --- Performance & Security Tradeoffs ---
    - mitigations=off                     # Disables CPU speculative execution mitigations
    - apparmor=0                          # Disable AppArmor LSM
    - security=none                       # Disable default security profile
    - init_on_alloc=0                     # Disable zeroing memory on allocation
    - init_on_free=0                      # Disable zeroing memory on free
    - talos.auditd.disabled=1             # Disable Linux audit daemon

    # --- Hardware Enablement & Virtualization ---
    - intel_iommu=on                      # Enable the IOMMU
    - iommu=pt                            # Use passthrough mode for IOMMU
    - i915.enable_guc=3                   # Enable GuC/HuC for 13th-gen Intel iGPU
    - sysctl.kernel.kexec_load_disabled=1 # Security hardening
    # - intel_pstate.energy_performance_preference=performance # Prioritize performance for Intel CPU

    # --- System Configuration ---
    - net.ifnames=0
    - tsc=reliable                        # i7-13620H has invariant TSC; skip kernel verification overhead
    # REMOVED 2026-07-22: thunderbolt.host_reset=0, pcie_ports=native, pcie_aspm=off,
    # pcie_port_pm=off. Added during the RTX 5070/AG02 link-stability investigation but
    # never conclusively fixed anything - that card's actual problem turned out to be an
    # unrelated NVIDIA Blackwell GSP-firmware bug (see project_egpu_k8s2 memory). k8s-2
    # then had 3+ unexplained hard reboots with no eGPU connected while running these
    # (globally disabling PCIe ASPM/power-management, not just on the Thunderbolt slot);
    # k8s-0/k8s-1 never had these args and never showed the same instability. Revisit
    # with real evidence if the RTX 3090 shows genuine link problems.
    # - pci=realloc,hpmmiosize=64M,hpmmioprefsize=8G # REVERTED 2026-07-19: caused a crash on AG02 reconnect severe enough that sd-boot auto-rolled-back the node to the previous UKI entry. Do not re-add without further investigation.
    - nvidia.NVreg_OpenRmEnableUnsupportedGpus=1 # Open kernel modules on consumer GeForce cards (RTX 3090/Ampere) have historically needed this to enable at all; harmless no-op if the driver no longer checks it

    # --- Intentionally left disabled ---
    # - elevator=mq-deadline              # Kernel auto-selects per device: none (NVMe), mq-deadline (SATA) — global override would harm NVMe
    # - nohz_full=4,5,6,7                # CPU tick isolation — marginal homelab benefit, complex to tune correctly
  systemExtensions:
    officialExtensions:
      - siderolabs/gasket-driver          # M.2 Google Coral accelerators
      - siderolabs/i915                   # Intel iGPU
      - siderolabs/intel-ucode            # Intel iGPU
      - siderolabs/mei                    # Intel Management Engine drivers
      - siderolabs/nfsrahead              # NFS Performance
      - siderolabs/nut-client             # Network UPS Tools
      {% if ENV.EGPU %}
      - siderolabs/nvidia-container-toolkit-production # eGPU (k8s-2 only) - exposes NVIDIA GPU to containers
      - siderolabs/nvidia-open-gpu-kernel-modules-production # eGPU (k8s-2 only) - RTX 3090 (Ampere); open kernel modules officially support Turing/Ampere/Ada/Blackwell, same extension works across the card swap
      {% endif %}
      - siderolabs/nvme-cli               # NVMe command line tools
      - siderolabs/thunderbolt             # USB4/TB4 PCIe tunneling (planned eGPU)
      - siderolabs/util-linux-tools       # Useful Linux tools
